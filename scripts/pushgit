#!/bin/bash
set -e

# -------- COLORS --------
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# -------- CONFIG --------
DEFAULT_MSG="update"

# -------- FUNCTIONS --------
usage() {
  echo "Usage: pushgit [-m message] [-a] [-p] [-b branch] [-n] [-h]"
  echo ""
  echo "  -m   Commit message (default: '$DEFAULT_MSG')"
  echo "  -a   Auto add all changes"
  echo "  -p   Pull with rebase before pushing"
  echo "  -b   Target branch (default: current branch)"
  echo "  -n   Dry run — show what would happen without doing it"
  echo "  -h   Show this help"
  exit 1
}

# -------- CHECK GIT REPO --------
if ! git rev-parse --git-dir &> /dev/null; then
  echo -e "${RED}❌ Not a Git repository.${NC}"
  exit 1
fi

# -------- PARSE FLAGS --------
AUTO_ADD=false
AUTO_PULL=false
DRY_RUN=false
MSG=""
BRANCH_OVERRIDE=""

while getopts ":m:apb:nh" opt; do
  case $opt in
    m) MSG="$OPTARG" ;;
    a) AUTO_ADD=true ;;
    p) AUTO_PULL=true ;;
    b) BRANCH_OVERRIDE="$OPTARG" ;;
    n) DRY_RUN=true ;;
    h) usage ;;
    *) usage ;;
  esac
done

# -------- SET DEFAULTS --------
MSG=${MSG:-$DEFAULT_MSG}
BRANCH=${BRANCH_OVERRIDE:-$(git branch --show-current)}

echo -e "🌿 Branch: ${CYAN}$BRANCH${NC}"
$DRY_RUN && echo -e "${YELLOW}🔍 Dry run mode — no changes will be made.${NC}"

# -------- PULL BEFORE PUSH --------
if $AUTO_PULL; then
  echo "⬇️  Pulling latest changes (rebase)..."
  $DRY_RUN || git pull --rebase origin "$BRANCH"
fi

# -------- AUTO ADD --------
if $AUTO_ADD; then
  echo "➕ Staging all changes..."
  $DRY_RUN || git add -A
fi

# -------- CHECK CHANGES --------
if [ -z "$(git status --porcelain)" ]; then
  echo -e "${YELLOW}⚠️  No changes to commit.${NC}"
  exit 0
fi

# -------- SHOW STAGED FILES --------
echo ""
echo -e "${CYAN}📋 Staged changes:${NC}"
git status --short
echo ""

# -------- CONFIRM --------
if ! $DRY_RUN; then
  read -rp "🚀 Commit with message \"$MSG\" and push to '$BRANCH'? [Y/n]: " CONFIRM
  if [[ "$CONFIRM" =~ ^[Nn]$ ]]; then
    echo "❌ Aborted."
    exit 0
  fi
fi

# -------- COMMIT & PUSH --------
if $DRY_RUN; then
  echo -e "${YELLOW}[dry-run] git commit -m \"$MSG\"${NC}"
  echo -e "${YELLOW}[dry-run] git push origin $BRANCH${NC}"
else
  git commit -m "$MSG"
  git push origin "$BRANCH"
  echo ""
  echo -e "${GREEN}✅ Pushed to '$BRANCH' successfully!${NC}"
fi