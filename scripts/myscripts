#!/bin/bash

# -------- CONFIG --------
SCRIPTS_DIR="$HOME/.my_scripts"

# -------- COLORS --------
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# -------- FUNCTIONS --------
usage() {
  echo -e "${CYAN}🛠️  myscripts — personal script manager${NC}"
  echo ""
  echo "Usage: myscripts <command> [name]"
  echo ""
  echo "  list              List all scripts"
  echo "  show  <name>      Print a script's contents"
  echo "  edit  <name>      Open a script in your editor"
  echo "  new   <name>      Create a new script with a bash template"
  echo "  delete <name>     Delete a script (asks for confirmation)"
  echo "  run   <name>      Run a script"
  echo ""
  exit 1
}

list_scripts() {
  echo -e "${CYAN}📂 Scripts in $SCRIPTS_DIR:${NC}"
  echo ""
  local count=0
  for f in "$SCRIPTS_DIR"/*; do
    [ -f "$f" ] || continue
    name=$(basename "$f")
    perms=$(ls -lh "$f" | awk '{print $1}')
    size=$(ls -lh "$f" | awk '{print $5}')
    echo -e "  ${GREEN}▸${NC} $name  ${YELLOW}($size)${NC}  $perms"
    ((count++))
  done
  echo ""
  echo -e "  Total: ${CYAN}$count script(s)${NC}"
}

show_script() {
  local name="$1"
  local path="$SCRIPTS_DIR/$name"
  if [ ! -f "$path" ]; then
    echo -e "${RED}❌ Script '$name' not found.${NC}"
    exit 1
  fi
  echo -e "${CYAN}── $name ──────────────────────────${NC}"
  cat "$path"
  echo -e "${CYAN}────────────────────────────────────${NC}"
}

edit_script() {
  local name="$1"
  local path="$SCRIPTS_DIR/$name"
  if [ ! -f "$path" ]; then
    echo -e "${RED}❌ Script '$name' not found. Use 'myscripts new $name' to create it.${NC}"
    exit 1
  fi
  ${EDITOR:-nano} "$path"
}

new_script() {
  local name="$1"
  local path="$SCRIPTS_DIR/$name"
  if [ -f "$path" ]; then
    echo -e "${YELLOW}⚠️  '$name' already exists. Use 'myscripts edit $name' to modify it.${NC}"
    exit 1
  fi
  cat > "$path" <<EOF
#!/bin/bash
set -e

# -------- $name --------
# Description: 
# Usage: $name

echo "Hello from $name!"
EOF
  chmod +x "$path"
  echo -e "${GREEN}✅ Created '$name'. Opening in editor...${NC}"
  ${EDITOR:-nano} "$path"
}

delete_script() {
  local name="$1"
  local path="$SCRIPTS_DIR/$name"
  if [ ! -f "$path" ]; then
    echo -e "${RED}❌ Script '$name' not found.${NC}"
    exit 1
  fi
  read -rp "⚠️  Delete '$name'? This cannot be undone. [y/N]: " CONFIRM
  if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
    rm "$path"
    echo -e "${GREEN}🗑️  '$name' deleted.${NC}"
  else
    echo "❌ Aborted."
  fi
}

run_script() {
  local name="$1"
  local path="$SCRIPTS_DIR/$name"
  if [ ! -f "$path" ]; then
    echo -e "${RED}❌ Script '$name' not found.${NC}"
    exit 1
  fi
  echo -e "${CYAN}▶ Running '$name'...${NC}"
  bash "$path"
}

# -------- MAIN --------
COMMAND=${1:-}
NAME=${2:-}

case "$COMMAND" in
  list)    list_scripts ;;
  show)    [ -z "$NAME" ] && usage; show_script "$NAME" ;;
  edit)    [ -z "$NAME" ] && usage; edit_script "$NAME" ;;
  new)     [ -z "$NAME" ] && usage; new_script "$NAME" ;;
  delete)  [ -z "$NAME" ] && usage; delete_script "$NAME" ;;
  run)     [ -z "$NAME" ] && usage; run_script "$NAME" ;;
  *)       usage ;;
esac