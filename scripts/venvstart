#!/bin/bash
set -e

# -------- CONFIG --------
ENV_NAME=${1:-venv}
PYTHON=${2:-python3}

# -------- COLORS --------
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# -------- CHECK PYTHON --------
if ! command -v "$PYTHON" &> /dev/null; then
  echo -e "${RED}❌ '$PYTHON' is not installed or not in PATH.${NC}"
  exit 1
fi

PYTHON_VERSION=$("$PYTHON" --version 2>&1)
echo -e "🐍 Using $PYTHON_VERSION"

# -------- EXISTING ENV CHECK --------
if [ -d "$ENV_NAME" ]; then
  echo -e "${YELLOW}⚠️  Environment '$ENV_NAME' already exists.${NC}"
  read -rp "   Recreate it? This will delete the existing one. [y/N]: " CONFIRM
  if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
    rm -rf "$ENV_NAME"
    echo "🗑️  Deleted old environment."
  else
    echo "👍 Keeping existing environment."
  fi
fi

# -------- CREATE VENV --------
if [ ! -d "$ENV_NAME" ]; then
  echo "📦 Creating virtual environment: '$ENV_NAME'..."
  "$PYTHON" -m venv "$ENV_NAME"
  echo -e "${GREEN}✅ Virtual environment created.${NC}"
fi

# -------- ACTIVATION HINT --------
echo ""
echo -e "${GREEN}🎉 Ready! To activate your environment, run:${NC}"
echo -e "   ${YELLOW}source $ENV_NAME/bin/activate${NC}"
echo ""
echo "👉 To deactivate later, run: deactivate"